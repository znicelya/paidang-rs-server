# ===== Application =====
# RUN_ENV selects config/<env>.toml on top of config/default.toml
RUN_ENV=development

# ===== Database (MySQL) =====
DATABASE_URL=mysql://root:root@127.0.0.1:3306/paidang

# ===== JWT =====
JWT_SECRET=change-me-in-production

# ===== WeChat mini-program =====
WX_APPID=
WX_SECRET=

# ===== Qiniu image moderation (optional; if absent, moderation returns "unknown") =====
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=

# ===== Tencent Cloud COS =====
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
