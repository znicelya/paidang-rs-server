# ===== Application =====
# RUN_ENV selects config/<env>.toml on top of config/default.toml
RUN_ENV=development

# ===== Database (MySQL) =====
DATABASE_URL=mysql://root:xxx@xxxx:3306/xxxxx

# ===== JWT =====
JWT_SECRET=change-me-in-production

# ===== WeChat mini-program =====
WX_APPID=xxxxx
WX_SECRET=xxxxx

# ===== Qiniu image moderation (optional; if absent, moderation returns "unknown") =====
QINIU_ACCESS_KEY=xxxxx
QINIU_SECRET_KEY=xxxxx

# ===== Tencent Cloud COS =====
COS_SECRET_ID=xxxxx
COS_SECRET_KEY=xxxxx
COS_BUCKET=xxxxx
COS_REGION=xxxxx
